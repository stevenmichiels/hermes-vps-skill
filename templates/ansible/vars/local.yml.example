# Copy to vars/local.yml and keep that file out of git.
# This file must contain only non-secret deployment identity/config values.

admin_user: "<admin_user>"
admin_authorized_keys:
  - "ssh-ed25519 <public-key> <label>"

# Managed parent directories for the VPS zoning model:
# /srv/apps, /home/<admin_user>/repos, /home/<admin_user>/agent-workspaces,
# /opt/openclaw, /opt/hermes, and /var/backups.
vps_zone_dirs_enabled: true

# First public bootstrap must use your current public IP /32.
# Leave empty only after Tailscale SSH is proven and disable_root_login=true.
bootstrap_public_ssh_cidr: ""
tailscale_ssh_source_cidr: "100.64.0.0/10"

# Hermes service starts only after /var/lib/hermes/.env is configured.
hermes_enable_service: false
hermes_require_telegram: true
hermes_require_allowed_users: true

# Optional dashboard; keep loopback-bound and use SSH tunnel/Tailscale.
hermes_dashboard_enabled: false

# Source-controlled Hermes runtime skills. Do not put secrets in this tree.
hermes_runtime_skills_enabled: true

# Python tooling baseline. Installs uv and uvx into /usr/local/bin.
install_uv: true
refresh_uv: false

# Optional helper for Codex -> Claude read-only review reports.
install_claude_review_helper: true
# Codex skill install path for the operator/admin user.
codex_skills_dir: "/home/{{ admin_user }}/.codex/skills"

# Optional gateway URL prefetch. When enabled, the gateway retrieves public
# HTTP(S) URLs before the first model call and passes the model artifact paths.
hermes_url_prefetch_enabled: false

# Optional private Firecrawl stack; keep loopback-bound.
install_firecrawl: false
firecrawl_enable_service: false
