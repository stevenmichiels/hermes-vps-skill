# Windmill environment file.
# Managed by Ansible only when missing; edit this file on the VPS.
# Never commit this file or paste its secrets into chat.

POSTGRES_PASSWORD=__SET_ME__
DATABASE_URL=postgres://postgres:__SET_ME__@postgres:5432/{{ windmill_postgres_db }}?sslmode=disable
LOG_MAX_SIZE={{ windmill_log_max_size }}
LOG_MAX_FILE={{ windmill_log_max_file }}
