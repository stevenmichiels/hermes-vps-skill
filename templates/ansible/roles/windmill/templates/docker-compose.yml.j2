services:
  postgres:
    image: "{{ windmill_postgres_image }}"
    restart: unless-stopped
    shm_size: 512m
    env_file:
      - "{{ windmill_env_file }}"
    environment:
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD}"
      POSTGRES_DB: "{{ windmill_postgres_db }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
    volumes:
      - "{{ windmill_data_dir }}/postgres:/var/lib/postgresql/data"
    logging:
      driver: json-file
      options:
        max-size: "${LOG_MAX_SIZE:-20m}"
        max-file: "${LOG_MAX_FILE:-5}"
        compress: "true"

  windmill-server:
    image: "{{ windmill_image }}"
    restart: unless-stopped
    env_file:
      - "{{ windmill_env_file }}"
    environment:
      DATABASE_URL: "${DATABASE_URL}"
      MODE: server
      BASE_URL: "{{ windmill_base_url }}"
    ports:
      - "{{ windmill_bind_address }}:{{ windmill_host_port }}:{{ windmill_internal_port }}"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - "{{ windmill_data_dir }}/logs:/tmp/windmill/logs"
    logging:
      driver: json-file
      options:
        max-size: "${LOG_MAX_SIZE:-20m}"
        max-file: "${LOG_MAX_FILE:-5}"
        compress: "true"

  windmill-worker:
    image: "{{ windmill_image }}"
    restart: unless-stopped
    privileged: {{ (windmill_worker_privileged | bool) | ternary('true', 'false') }}
    deploy:
      replicas: {{ windmill_default_worker_replicas }}
      resources:
        limits:
          memory: 1536M
    env_file:
      - "{{ windmill_env_file }}"
    environment:
      DATABASE_URL: "${DATABASE_URL}"
      MODE: worker
      WORKER_GROUP: default
      FAVOR_UNSHARE_PID: "{{ (windmill_favor_unshare_pid | bool) | ternary('true', 'false') }}"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - "{{ windmill_data_dir }}/worker-cache:/tmp/windmill/cache"
      - "{{ windmill_data_dir }}/logs:/tmp/windmill/logs"
    logging:
      driver: json-file
      options:
        max-size: "${LOG_MAX_SIZE:-20m}"
        max-file: "${LOG_MAX_FILE:-5}"
        compress: "true"

  windmill-worker-native:
    image: "{{ windmill_image }}"
    restart: unless-stopped
    deploy:
      replicas: {{ windmill_native_worker_replicas }}
      resources:
        limits:
          memory: 512M
    env_file:
      - "{{ windmill_env_file }}"
    environment:
      DATABASE_URL: "${DATABASE_URL}"
      MODE: worker
      WORKER_GROUP: native
      NATIVE_MODE: "true"
      SLEEP_QUEUE: "200"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - "{{ windmill_data_dir }}/logs:/tmp/windmill/logs"
    logging:
      driver: json-file
      options:
        max-size: "${LOG_MAX_SIZE:-20m}"
        max-file: "${LOG_MAX_FILE:-5}"
        compress: "true"

  windmill-extra:
    image: "{{ windmill_extra_image }}"
    restart: unless-stopped
    environment:
      ENABLE_LSP: "{{ (windmill_enable_lsp | bool) | ternary('true', 'false') }}"
      ENABLE_MULTIPLAYER: "false"
      ENABLE_DEBUGGER: "{{ (windmill_enable_debugger | bool) | ternary('true', 'false') }}"
      DEBUGGER_PORT: "3003"
      ENABLE_NSJAIL: "false"
      REQUIRE_SIGNED_DEBUG_REQUESTS: "false"
      WINDMILL_BASE_URL: "http://windmill-server:8000"
    volumes:
      - "{{ windmill_data_dir }}/lsp-cache:/pyls/.cache"
    logging:
      driver: json-file
      options:
        max-size: "${LOG_MAX_SIZE:-20m}"
        max-file: "${LOG_MAX_FILE:-5}"
        compress: "true"
