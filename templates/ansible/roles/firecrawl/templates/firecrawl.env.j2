# Firecrawl environment (managed by Ansible).
# Replace placeholder values before enabling Firecrawl, or set
# firecrawl_auto_generate_secrets=true.

FIRECRAWL_IMAGE={{ firecrawl_image | default('ghcr.io/firecrawl/firecrawl:latest') }}
FIRECRAWL_PLAYWRIGHT_IMAGE={{ firecrawl_playwright_image | default('ghcr.io/firecrawl/playwright-service:latest') }}
FIRECRAWL_POSTGRES_IMAGE={{ firecrawl_postgres_image | default('ghcr.io/firecrawl/nuq-postgres:latest') }}

PORT={{ firecrawl_api_port | default(3002) }}
INTERNAL_PORT={{ firecrawl_internal_port | default(3002) }}
USE_DB_AUTHENTICATION={{ (firecrawl_use_db_authentication | default(false)) | ternary('true', 'false') }}

POSTGRES_USER={{ firecrawl_postgres_user | default('firecrawl') }}
POSTGRES_PASSWORD=__SET_ME__
POSTGRES_DB={{ firecrawl_postgres_db | default('postgres') }}
BULL_AUTH_KEY=__SET_ME__

# Low-concurrency defaults for a 4 CPU / 8 GB VPS.
NUM_WORKERS_PER_QUEUE={{ firecrawl_num_workers_per_queue | default(2) }}
CRAWL_CONCURRENT_REQUESTS={{ firecrawl_crawl_concurrent_requests | default(2) }}
MAX_CONCURRENT_JOBS={{ firecrawl_max_concurrent_jobs | default(1) }}
BROWSER_POOL_SIZE={{ firecrawl_browser_pool_size | default(1) }}
PLAYWRIGHT_CPUS={{ firecrawl_playwright_cpus | default('1.0') }}
PLAYWRIGHT_MEM_LIMIT={{ firecrawl_playwright_mem_limit | default('1536m') }}
API_CPUS={{ firecrawl_api_cpus | default('2.0') }}
API_MEM_LIMIT={{ firecrawl_api_mem_limit | default('3g') }}
MAX_CPU={{ firecrawl_max_cpu | default('0.85') }}
MAX_RAM={{ firecrawl_max_ram | default('0.85') }}
BLOCK_MEDIA={{ (firecrawl_block_media | default(true)) | ternary('true', 'false') }}
LOGGING_LEVEL={{ firecrawl_logging_level | default('INFO') }}
FIRECRAWL_HERMES_NETWORK={{ firecrawl_hermes_network | default('hermes_default') }}

# Optional AI/proxy/search integrations.
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_EMBEDDING_NAME=
OLLAMA_BASE_URL=
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
SEARXNG_ENDPOINT=
SEARXNG_ENGINES=
SEARXNG_CATEGORIES=
