services:
  n8n:
    image: "{{ n8n_image }}"
    container_name: n8n
    restart: unless-stopped
    init: true
    user: "{{ n8n_container_uid }}:{{ n8n_container_gid }}"
    env_file:
      - "{{ n8n_env_file }}"
    environment:
      DB_TYPE: sqlite
      N8N_PORT: "5678"
      N8N_LISTEN_ADDRESS: "0.0.0.0"
      N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS: "true"
      N8N_RUNNERS_ENABLED: "true"
      N8N_SECURE_COOKIE: "{{ (n8n_secure_cookie | bool) | ternary('true', 'false') }}"
      N8N_EDITOR_BASE_URL: "{{ n8n_editor_base_url }}"
      N8N_PROXY_HOPS: "{{ n8n_proxy_hops }}"
      N8N_BLOCK_ENV_ACCESS_IN_NODE: "true"
{% if n8n_public_hostname | length > 0 %}
      N8N_HOST: "{{ n8n_public_hostname }}"
      N8N_PROTOCOL: "https"
      WEBHOOK_URL: "{{ n8n_webhook_url | default('https://' ~ n8n_public_hostname ~ '/', true) }}"
{% endif %}
      GENERIC_TIMEZONE: "{{ n8n_timezone }}"
      TZ: "{{ n8n_timezone }}"
    ports:
      - "{{ n8n_bind_address }}:{{ n8n_host_port }}:5678"
    volumes:
      - "{{ n8n_data_dir }}/data:/home/node/.n8n"
      - "{{ n8n_data_dir }}/files:/files"
