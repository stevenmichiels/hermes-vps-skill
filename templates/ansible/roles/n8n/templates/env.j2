# n8n environment file.
# Managed by Ansible only when missing; edit this file on the VPS.
# Never commit this file or paste its secrets into chat.

N8N_ENCRYPTION_KEY=__SET_ME__
N8N_USER_MANAGEMENT_JWT_SECRET=__SET_ME__
N8N_EDITOR_BASE_URL={{ n8n_editor_base_url }}
N8N_PROXY_HOPS={{ n8n_proxy_hops }}
N8N_SECURE_COOKIE={{ (n8n_secure_cookie | bool) | ternary('true', 'false') }}
DB_TYPE=sqlite
{% if n8n_public_hostname | length > 0 %}
N8N_HOST={{ n8n_public_hostname }}
N8N_PROTOCOL=https
WEBHOOK_URL={{ n8n_webhook_url | default('https://' ~ n8n_public_hostname ~ '/', true) }}
{% endif %}

# Do not set N8N_SKIP_AUTH_ON_OAUTH_CALLBACK=true.
