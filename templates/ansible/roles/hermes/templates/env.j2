# Hermes Agent environment.
# This file lives in the Hermes data directory and is mounted into the container at /opt/data/.env.
# Fill locally on the VPS. Do not commit real values.

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# GATEWAY_ALLOWED_USERS=

# Required when publishing/checking the local OpenAI-compatible API and health endpoint.
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=

