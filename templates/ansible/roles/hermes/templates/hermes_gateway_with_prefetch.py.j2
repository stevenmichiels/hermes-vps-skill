#!/usr/bin/env python3
"""Run Hermes gateway with public URL material prepared before model calls.

This wrapper is intentionally small and reversible. It monkey-patches the
gateway message preparation step, retrieves public HTTP(S) URLs through the
private Firecrawl service when available, writes artifacts under /opt/data,
and replaces risky URL-task wording with a neutral artifact handoff.
"""

from __future__ import annotations

import asyncio
import datetime as dt
import hashlib
import html
import ipaddress
import json
import os
import re
import socket
import sys
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any


URL_RE = re.compile(r"https?://[^\s<>'\"\]\)]+", re.IGNORECASE)
TRAILING_PUNCTUATION = ".,;:!?"

ENABLED = os.environ.get("HERMES_URL_PREFETCH_ENABLED", "1").lower() in {
    "1",
    "true",
    "yes",
    "on",
}
MAX_URLS = int(os.environ.get("HERMES_URL_PREFETCH_MAX_URLS", "3") or "3")
MAX_INLINE_CHARS = int(
    os.environ.get("HERMES_URL_PREFETCH_INLINE_CHARS", "12000") or "12000"
)
ARTIFACT_DIR = Path(
    os.environ.get(
        "HERMES_URL_PREFETCH_ARTIFACT_DIR",
        "/opt/data/artifacts/url-prefetch",
    )
)
FIRECRAWL_URL = os.environ.get(
    "HERMES_URL_PREFETCH_FIRECRAWL_URL",
    "http://firecrawl:3002/v1/scrape",
)

REQUEST_REWRITES = (
    (re.compile(r"\bprivate-firecrawl\b", re.IGNORECASE), "gateway URL reader"),
    (re.compile(r"\bfirecrawl\b", re.IGNORECASE), "URL reader"),
    (re.compile(r"\bcrawl(?:en|ed|ing|s|er|ers)?\b", re.IGNORECASE), "read"),
    (re.compile(r"\bscrap(?:e|en|ed|ing|es|er|ers)?\b", re.IGNORECASE), "extract"),
)


def _extract_urls(text: str) -> list[str]:
    urls: list[str] = []
    seen: set[str] = set()
    for match in URL_RE.finditer(text or ""):
        url = match.group(0).rstrip(TRAILING_PUNCTUATION)
        if url not in seen:
            seen.add(url)
            urls.append(url)
        if len(urls) >= MAX_URLS:
            break
    return urls


def _is_global_host(hostname: str) -> tuple[bool, str]:
    if not hostname:
        return False, "missing-host"
    if hostname.lower() in {"localhost", "localhost.localdomain"}:
        return False, "local-host"

    try:
        candidates = {hostname}
        try:
            ascii_host = hostname.encode("idna").decode("ascii")
            candidates.add(ascii_host)
        except UnicodeError:
            pass

        addresses: set[str] = set()
        for candidate in candidates:
            for family, _, _, _, sockaddr in socket.getaddrinfo(candidate, None):
                if family in (socket.AF_INET, socket.AF_INET6):
                    addresses.add(sockaddr[0])
    except socket.gaierror as exc:
        return False, f"dns-failed:{exc}"

    if not addresses:
        return False, "no-address"

    for address in addresses:
        try:
            ip = ipaddress.ip_address(address)
        except ValueError:
            return False, f"bad-address:{address}"
        if not ip.is_global:
            return False, f"non-public-address:{address}"
    return True, ""


def _is_safe_public_url(url: str) -> tuple[bool, str]:
    parsed = urllib.parse.urlparse(url)
    if parsed.scheme not in {"http", "https"}:
        return False, "unsupported-scheme"
    if parsed.username or parsed.password:
        return False, "userinfo-not-allowed"
    ok, reason = _is_global_host(parsed.hostname or "")
    if not ok:
        return False, reason
    return True, ""


def _slug_for_url(url: str) -> str:
    parsed = urllib.parse.urlparse(url)
    base = (parsed.netloc + parsed.path).strip("/") or "url"
    base = re.sub(r"[^A-Za-z0-9._-]+", "-", base).strip("-")[:80] or "url"
    digest = hashlib.sha256(url.encode("utf-8")).hexdigest()[:10]
    return f"{base}-{digest}"


def _post_json(url: str, payload: dict[str, Any], timeout: float = 75.0) -> dict[str, Any]:
    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=timeout) as response:
        return json.loads(response.read().decode("utf-8", "replace"))


def _direct_text_fallback(url: str, timeout: float = 30.0) -> dict[str, Any]:
    request = urllib.request.Request(
        url,
        headers={"User-Agent": "HermesGatewayURLPrefetch/1.0"},
    )
    with urllib.request.urlopen(request, timeout=timeout) as response:
        content_type = response.headers.get("content-type", "")
        raw = response.read(1_500_000).decode("utf-8", "replace")

    text = re.sub(r"(?is)<(script|style).*?</\1>", " ", raw)
    text = re.sub(r"(?s)<[^>]+>", " ", text)
    text = html.unescape(text)
    text = re.sub(r"\s+", " ", text).strip()
    markdown = f"Source: {url}\nContent-Type: {content_type}\n\n{text}\n"
    return {"markdown": markdown, "links": [], "method": "direct-http"}


def _retrieve_url(url: str) -> dict[str, Any]:
    ok, reason = _is_safe_public_url(url)
    if not ok:
        return {"url": url, "ok": False, "error": reason}

    method = "private-firecrawl"
    try:
        payload = {
            "url": url,
            "formats": ["markdown", "links"],
            "onlyMainContent": False,
        }
        result = _post_json(FIRECRAWL_URL, payload)
        data = result.get("data") if isinstance(result, dict) else None
        if not isinstance(data, dict):
            data = result if isinstance(result, dict) else {}
        markdown = str(data.get("markdown") or "")
        links = data.get("links") or []
        if not markdown.strip():
            raise RuntimeError("empty markdown")
    except Exception as firecrawl_error:
        try:
            fallback = _direct_text_fallback(url)
            markdown = fallback["markdown"]
            links = fallback["links"]
            method = fallback["method"]
        except Exception as fallback_error:
            return {
                "url": url,
                "ok": False,
                "error": (
                    f"private-firecrawl failed: {type(firecrawl_error).__name__}; "
                    f"direct fallback failed: {type(fallback_error).__name__}"
                ),
            }

    stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    out_dir = ARTIFACT_DIR / stamp
    out_dir.mkdir(parents=True, exist_ok=True)
    slug = _slug_for_url(url)
    md_path = out_dir / f"{slug}.md"
    json_path = out_dir / f"{slug}.json"

    meta = {
        "url": url,
        "retrieved_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "method": method,
        "markdown_chars": len(markdown),
        "links_count": len(links) if isinstance(links, list) else 0,
    }
    md_path.write_text(markdown, encoding="utf-8")
    json_path.write_text(
        json.dumps({"meta": meta, "links": links}, ensure_ascii=False, indent=2) + "\n",
        encoding="utf-8",
    )
    return {
        "url": url,
        "ok": True,
        "meta": meta,
        "markdown": markdown,
        "markdown_path": str(md_path),
        "json_path": str(json_path),
    }


def _normalize_request(text: str, urls: list[str]) -> str:
    normalized = text or ""
    for idx, url in enumerate(urls, start=1):
        normalized = normalized.replace(url, f"[url-{idx}]")
    for pattern, replacement in REQUEST_REWRITES:
        normalized = pattern.sub(replacement, normalized)
    normalized = re.sub(r"\s+", " ", normalized).strip()
    if not normalized:
        normalized = "Please help with the retrieved public URL material."
    return normalized[:1200]


def _build_prefetch_message(original_text: str, urls: list[str]) -> str | None:
    results = [_retrieve_url(url) for url in urls]
    if not any(result.get("ok") for result in results):
        return None

    inline_budget = max(0, MAX_INLINE_CHARS)
    lines: list[str] = [
        "[Gateway public URL material]",
        "The gateway retrieved the public URL material before invoking the model.",
        "Use the saved artifact paths as source material. If the excerpt is short, read the artifact file for full content.",
        "",
    ]

    for idx, result in enumerate(results, start=1):
        lines.append(f"{idx}. URL: {result['url']}")
        if not result.get("ok"):
            lines.append(f"   status: skipped ({result.get('error', 'unknown error')})")
            lines.append("")
            continue

        meta = result["meta"]
        display_method = (
            "private-url-reader"
            if meta["method"] == "private-firecrawl"
            else meta["method"]
        )
        lines.append("   status: retrieved")
        lines.append(f"   method: {display_method}")
        lines.append(f"   artifact_markdown: {result['markdown_path']}")
        lines.append(f"   artifact_json: {result['json_path']}")
        lines.append(f"   markdown_chars: {meta['markdown_chars']}")
        lines.append(f"   links_count: {meta['links_count']}")

        if inline_budget > 0:
            markdown = result.get("markdown") or ""
            excerpt = markdown[:inline_budget]
            inline_budget -= len(excerpt)
            lines.append("   excerpt:")
            lines.append("```text")
            lines.append(excerpt.replace("```", "'''"))
            if len(markdown) > len(excerpt):
                lines.append("\n[Excerpt truncated. Read artifact_markdown for full content.]")
            lines.append("```")
        lines.append("")

    lines.append("[/Gateway public URL material]")
    lines.append("")
    lines.append(f"User request, normalized: {_normalize_request(original_text, urls)}")
    return "\n".join(lines)


def install_gateway_patch() -> None:
    if not ENABLED:
        return

    from gateway.run import GatewayRunner

    if getattr(GatewayRunner, "_url_prefetch_patch_installed", False):
        return

    original = GatewayRunner._prepare_inbound_message_text

    async def patched_prepare_inbound_message_text(self, event, source, history):
        message_text = await original(
            self,
            event=event,
            source=source,
            history=history,
        )
        if message_text is None:
            return None

        raw_text = str(getattr(event, "text", "") or "")
        if raw_text.lstrip().startswith("/"):
            return message_text
        urls = _extract_urls(raw_text)
        if not urls:
            return message_text

        loop = asyncio.get_running_loop()
        prefetch_message = await loop.run_in_executor(
            None,
            lambda: _build_prefetch_message(raw_text, urls),
        )
        if not prefetch_message:
            return message_text
        return prefetch_message

    GatewayRunner._prepare_inbound_message_text = patched_prepare_inbound_message_text
    GatewayRunner._url_prefetch_patch_installed = True


def main() -> int:
    install_gateway_patch()
    from hermes_cli.main import main as hermes_main

    sys.argv = ["hermes", *sys.argv[1:]]
    return int(hermes_main() or 0)


if __name__ == "__main__":
    raise SystemExit(main())
