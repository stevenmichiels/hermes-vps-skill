#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-status}"
shift || true

needs_root() {
  case "$cmd" in
    status|backup|release-check|healthcheck|docker-cleanup|timers)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if needs_root && [ "${EUID:-$(id -u)}" -ne 0 ]; then
  exec sudo /usr/local/bin/hermes-vps "$cmd" "$@"
fi

case "$cmd" in
  status)
    exec /usr/local/sbin/hermes-vps-status "$@"
    ;;
  backup)
    exec /usr/local/sbin/hermes-vps-backup "$@"
    ;;
  release-check)
    exec /usr/local/sbin/hermes-vps-release-check "$@"
    ;;
  healthcheck)
    exec /usr/local/sbin/hermes-vps-healthcheck "$@"
    ;;
  docker-cleanup)
    exec /usr/local/sbin/hermes-docker-cleanup "$@"
    ;;
  timers)
    exec systemctl list-timers --all hermes-vps-backup.timer hermes-docker-cleanup.timer hermes-vps-release-check.timer hermes-vps-healthcheck.timer
    ;;
  help|-h|--help)
    cat <<'USAGE'
Usage: hermes-vps <command>

Commands:
  status          Run the full Hermes VPS healthcheck
  backup          Create an immediate Hermes VPS backup
  release-check   Check for a newer stable Hermes release
  healthcheck     Run status and send Telegram transition alerts
  docker-cleanup  Prune unused Docker containers/images/build cache
  timers          Show Hermes VPS timers
USAGE
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Run: hermes-vps help" >&2
    exit 2
    ;;
esac
