#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="{{ hermes_monitor_state_dir }}"
STATE_FILE="${STATE_DIR}/last-health-state"
LOG_FILE="$(mktemp)"
mkdir -p "$STATE_DIR"
chmod 0700 "$STATE_DIR"

set +e
/usr/local/sbin/hermes-vps-status >"$LOG_FILE" 2>&1
rc=$?
set -e

if [ "$rc" -eq 0 ]; then
  new_state="healthy"
else
  new_state="unhealthy"
fi

old_state="$(cat "$STATE_FILE" 2>/dev/null || true)"
printf '%s\n' "$new_state" >"$STATE_FILE"

cat "$LOG_FILE"

if [ "$new_state" != "$old_state" ]; then
  read_env_value() {
    local env_file="$1" key_pattern="$2"
    grep -E "^(${key_pattern})=" "$env_file" 2>/dev/null |
      head -n1 |
      cut -d= -f2- |
      cut -d, -f1 |
      sed -e 's/^["'\'']//; s/["'\'']$//' || true
  }

  env_file="{{ vps_ops_env_file }}"
  legacy_env_file="{{ hermes_env_file }}"
  token="$(read_env_value "$env_file" "TELEGRAM_BOT_TOKEN")"
  chat_id="$(read_env_value "$env_file" "TELEGRAM_ALLOWED_USERS|GATEWAY_ALLOWED_USERS")"
  if [ -z "$token" ] && [ -f "$legacy_env_file" ]; then
    token="$(read_env_value "$legacy_env_file" "TELEGRAM_BOT_TOKEN")"
  fi
  if [ -z "$chat_id" ] && [ -f "$legacy_env_file" ]; then
    chat_id="$(read_env_value "$legacy_env_file" "TELEGRAM_ALLOWED_USERS|GATEWAY_ALLOWED_USERS")"
  fi
  if [ -n "$token" ] && [ -n "$chat_id" ]; then
    text="Hermes VPS health changed: ${old_state:-unknown} -> ${new_state}"
    curl -fsS -X POST "https://api.telegram.org/bot${token}/sendMessage" \
      -d "chat_id=${chat_id}" \
      --data-urlencode "text=${text}" >/dev/null 2>&1 || true
  fi
fi

rm -f "$LOG_FILE"
exit "$rc"
