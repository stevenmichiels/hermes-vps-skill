#!/usr/bin/env bash
set -euo pipefail
umask 077

BACKUP_DIR="{{ hermes_backup_dir }}"
RETENTION_DAYS="{{ hermes_backup_retention_days }}"
OFFBOX_ENABLED="{{ (hermes_backup_offbox_enabled | bool) | ternary('true', 'false') }}"
OFFBOX_STATE_FILE="{{ hermes_backup_offbox_state_file }}"
OFFBOX_MAX_AGE_HOURS="{{ hermes_backup_offbox_max_age_hours }}"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
ARCHIVE="${BACKUP_DIR}/hermes-vps-${STAMP}.tar.gz"
TMP_ARCHIVE="${ARCHIVE}.tmp"

mkdir -p "$BACKUP_DIR"
chmod 0700 "$BACKUP_DIR"

backup_paths=()

if [ -d /etc/hermes-vps ]; then
  backup_paths+=(etc/hermes-vps)
fi

if [ -d /etc/hermes ]; then
  backup_paths+=(etc/hermes)
fi

if [ -d /var/lib/hermes ]; then
  backup_paths+=(var/lib/hermes)
fi

if [ -d /etc/firecrawl ]; then
  backup_paths+=(etc/firecrawl)
fi

if [ -d /etc/n8n ]; then
  backup_paths+=(etc/n8n)
fi

if [ -d /var/lib/n8n ]; then
  backup_paths+=(var/lib/n8n)
fi

if [ -d /etc/windmill ]; then
  backup_paths+=(etc/windmill)
fi

if [ -d /var/lib/windmill ]; then
  backup_paths+=(var/lib/windmill)
fi

cd /
if [ -z "${backup_paths[*]:-}" ]; then
  printf 'backup_failed=no_paths_found\n' >&2
  exit 1
fi

tar \
  --ignore-failed-read \
  --warning=no-file-changed \
  -czf "$TMP_ARCHIVE" \
  "${backup_paths[@]}"

chmod 0600 "$TMP_ARCHIVE"
mv "$TMP_ARCHIVE" "$ARCHIVE"
ln -sfn "$(basename "$ARCHIVE")" "${BACKUP_DIR}/latest.tar.gz"

if [ "$OFFBOX_ENABLED" = "true" ]; then
  if ! /usr/local/sbin/hermes-vps-backup-offbox "$ARCHIVE"; then
    printf 'backup_offbox_retry_pending=%s\n' "$ARCHIVE"
  fi
fi

offbox_fresh=false
if [ "$OFFBOX_ENABLED" = "true" ] && [ -f "$OFFBOX_STATE_FILE" ]; then
  offbox_age="$(( ($(date +%s) - $(stat -c %Y "$OFFBOX_STATE_FILE")) / 3600 ))"
  if [ "$offbox_age" -le "$OFFBOX_MAX_AGE_HOURS" ]; then
    offbox_fresh=true
  fi
fi

if [ "$offbox_fresh" = "true" ]; then
  find "$BACKUP_DIR" -maxdepth 1 -type f -name 'hermes-vps-*.tar.gz' -mtime +"$RETENTION_DAYS" -print -delete |
    sed 's/^/backup_pruned=/'
  printf 'backup_retention_prune=guarded_by_fresh_offbox_copy\n'
else
  printf 'backup_retention_prune=disabled_until_offbox_copy\n'
fi

printf 'backup_created=%s\n' "$ARCHIVE"
